    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  const text = item.json?.candidates?.[0]?.content?.parts?.[0]?.text ?? null;\n\n  let clean = null;\n  let parsed = null;\n  let error = null;\n\n  if (typeof text === 'string' && text.trim()) {\n    clean = text\n      .replace(/^```json\\s*/i, '')\n      .replace(/^```\\s*/i, '')\n      .replace(/\\s*```$/i, '')\n      .trim();\n\n    try {\n      parsed = JSON.parse(clean);\n\n      // Gemini always normalizes bounding boxes to a 0-1000 grid,\n      // regardless of the source image's real resolution.\n      if (parsed && Array.isArray(parsed.detections)) {\n        parsed.image_width = 1000;\n        parsed.image_height = 1000;\n      }\n    } catch (err) {\n      error = { message: err.message, raw: clean };\n    }\n  } else {\n    error = { message: 'No valid text found', raw: text };\n  }\n\n  return {\n    json: {\n      success: parsed !== null,\n      data: parsed,\n      error: error\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -176,
        32
      ],
      "id": "11e7b173-5167-411d-b9b8-3766e5c996a1",
      "name": "convert json md to plain json2"
    },
    {
