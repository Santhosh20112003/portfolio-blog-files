    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet filename = null;\nconst detections = [];\n\nfor (const item of items) {\n  const json = item.json;\n\n  if (json.filename) {\n    filename = json.filename;\n  } else if (json.success !== undefined) {\n    detections.push(json);\n  }\n}\n\nreturn [\n  {\n    json: {\n      data:{\n      filename,\n      detections\n    }\n    }\n  }\n];"
      },
